# Football Data Provider (Free Mode)
FOOTBALL_DATA_MODE=free

# Primary: API-Football Free Plan (https://www.api-football.com/)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Backup: football-data.org (optional)
FOOTBALL_DATA_ORG_KEY=
FOOTBALL_DATA_ORG_BASE_URL=https://api.football-data.org/v4

# Daily request budget for free mode (default: 100)
FREE_DAILY_API_LIMIT=100

# Beta Recommendation + Continuous Validation
BETA_RECOMMENDATION_MODE=true
NEXT_PUBLIC_BETA_RECOMMENDATION_MODE=true

# Supabase (server-only; used by /api/data/* routes)
SUPABASE_URL=
# Secret key (sb_secret_...) OR Legacy service_role JWT (eyJ...)
# Dashboard: Project Settings → API Keys → Secret keys
# Legacy JWT: Project Settings → API → Legacy API Keys tab → service_role → Reveal
SUPABASE_SERVICE_ROLE_KEY=

# One-time admin repair API (POST /api/admin/repair-implied-probability)
ADMIN_REPAIR_KEY=
