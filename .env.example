# Football Data Provider (Free Mode)
FOOTBALL_DATA_MODE=free

# Primary: API-Football (https://www.api-football.com/)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Backup: football-data.org (optional)
FOOTBALL_DATA_ORG_KEY=
FOOTBALL_DATA_ORG_BASE_URL=https://api.football-data.org/v4

# Daily request budget for free mode (default: 100)
FREE_DAILY_API_LIMIT=100

# Beta Recommendation + Continuous Validation
BETA_RECOMMENDATION_MODE=true
NEXT_PUBLIC_BETA_RECOMMENDATION_MODE=true

# Supabase (server-only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# RC2 Security (server-only — never expose to browser)
ADMIN_API_KEY=
CRON_SECRET=

# Deprecated: use ADMIN_API_KEY instead (temporary fallback only)
# ADMIN_REPAIR_KEY=

# Admin dashboard API auth (default: true)
ADMIN_DASHBOARD_REQUIRE_AUTH=true

# Google Gemini Grounding (server-only)
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-2.0-flash

# Scheduler (V5 / RC3)
SCHEDULER_ENABLED=true
# Prefer league ID whitelist (API-Football IDs). Leave empty to analyze all leagues with valid league.id.
SCHEDULER_LEAGUE_ID_WHITELIST=
# Optional name fallback when SCHEDULER_LEAGUE_ID_WHITELIST is empty and you want name-based filtering
SCHEDULER_LEAGUE_WHITELIST=
SCHEDULER_DAILY_HOUR_UTC=0
SCHEDULER_RESULT_HOUR_UTC=15
SCHEDULER_LOCK_TTL_MS=1800000
SCHEDULER_FIXTURE_TIMEOUT_MS=60000
SCHEDULER_JOB_TIMEOUT_MS=900000
SCHEDULER_TIME_BUDGET_MS=240000
SCHEDULER_MAX_FIXTURES_PER_RUN=3
SCHEDULER_MAX_TEAM_PROFILE_REFRESHS_PER_RUN=4
SCHEDULER_MAX_RETRIES=3
SCHEDULER_RETRY_DELAY_MS=500

# Historical match backfill (H2H / learning history)
HISTORICAL_BACKFILL_MAX_PER_RUN=100
HISTORICAL_BACKFILL_FREE_PLAN_LOOKBACK_DAYS=2
# HISTORICAL_BACKFILL_START_DATE defaults to yesterday
# HISTORICAL_BACKFILL_MIN_DATE defaults to yesterday minus lookback days

# Team Profile Engine (V2.1)
TEAM_PROFILE_TTL_HOURS=24

# Rate limit adapter: supabase (default) | memory (tests only)
RATE_LIMIT_ADAPTER=supabase
